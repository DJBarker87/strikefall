# Copy to .env, then replace every required placeholder before starting Compose.
# Never commit the populated file.
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
STRIKEFALL_SIGNING_KEY=replace-with-64-hex-characters-from-openssl-rand-hex-32

# Browser origin and published local edge port.
STRIKEFALL_ALLOWED_ORIGIN=http://localhost:4173
# Required production acknowledgement while live SSE fan-out is process-local.
# Keep the round service at exactly one replica.
STRIKEFALL_STREAM_TOPOLOGY=single-replica
STRIKEFALL_WEB_BIND=127.0.0.1
STRIKEFALL_WEB_PORT=4173

# Closed-alpha access. Leave invite codes entirely absent when this is false.
STRIKEFALL_REQUIRE_INVITE=false
# STRIKEFALL_INVITE_CODES=alpha-code-one,alpha-code-two
STRIKEFALL_SESSION_TTL_HOURS=168

# Consent-gated telemetry retention. Metrics stay disabled unless a token exists.
STRIKEFALL_TELEMETRY_RETENTION_DAYS=30
# STRIKEFALL_METRICS_TOKEN=replace-with-a-long-random-operator-token
# Public/default sessions omit deck-structure and rotate all four decks. This
# optional override keeps that policy while narrowing the other valid variants.
# STRIKEFALL_EXPERIMENTS_JSON={"escape:v2":["absent","midpoint"],"risk-display:v2":["probability","danger-band"]}
# Explicit closed-alpha deck A/B. Set both lines to activate the same disclosed
# policy in ranked and local Practice; assignments remain separate by subject.
# STRIKEFALL_EXPERIMENTS_JSON={"deck-structure:v2":["flat","compression-break"],"escape:v2":["absent","midpoint"],"risk-display:v2":["probability","danger-band"]}
# VITE_STRIKEFALL_DECK_STRUCTURE_EXPERIMENT=closed-alpha

# Keep 127.0.0.1/32 for direct HTTP development. When an external TLS gateway
# fronts the web container, set its exact source CIDR and make it overwrite
# X-Real-IP with the verified client address.
STRIKEFALL_EDGE_TRUSTED_PROXY_CIDR=127.0.0.1/32

# Optional operational tuning.
# STRIKEFALL_RECOVERY_CONCURRENCY=4
RUST_LOG=strikefall_round_service=info,tower_http=info
