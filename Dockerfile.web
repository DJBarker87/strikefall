# syntax=docker/dockerfile:1.7@sha256:a57df69d0ea827fb7266491f2813635de6f17269be881f696fbfdf2d83dda33e
ARG STRIKEFALL_BUILD_REVISION=unbound

FROM node:22.17.0-alpine3.22@sha256:fc3e945f920b7e3000cd1af86c4ae406ec70c72f328b667baf0f3a8910d69eed AS builder

WORKDIR /workspace
ENV CI=true

COPY package.json package-lock.json ./
RUN --mount=type=cache,id=strikefall-web-npm,target=/root/.npm \
    npm ci --no-audit --no-fund

COPY . .
ARG VITE_ROUND_API_URL=/api
ARG VITE_STRIKEFALL_DECK_STRUCTURE_EXPERIMENT=
ENV VITE_ROUND_API_URL=${VITE_ROUND_API_URL}
ENV VITE_STRIKEFALL_DECK_STRUCTURE_EXPERIMENT=${VITE_STRIKEFALL_DECK_STRUCTURE_EXPERIMENT}
RUN npm run build \
    && test -s dist/index.html \
    && find dist -type f -name '*.wasm' -size +0 -print -quit | grep -q .

FROM nginxinc/nginx-unprivileged:1.28.0-alpine3.21@sha256:c97ff0bf7cbae369953c6da1232ec14ad9f971d66360c5698db0856a4cd657a0 AS runtime
ARG STRIKEFALL_BUILD_REVISION
LABEL org.opencontainers.image.revision=$STRIKEFALL_BUILD_REVISION

ENV NGINX_ENTRYPOINT_LOCAL_RESOLVERS=1 \
    NGINX_ENVSUBST_OUTPUT_DIR=/tmp \
    NGINX_ENVSUBST_FILTER='^(NGINX_LOCAL_RESOLVERS|STRIKEFALL_EDGE_TRUSTED_PROXY_CIDR)$' \
    NGINX_LOCAL_RESOLVERS=127.0.0.11 \
    STRIKEFALL_EDGE_TRUSTED_PROXY_CIDR=127.0.0.1/32

RUN rm -f /etc/nginx/conf.d/default.conf
COPY deploy/nginx/nginx.conf /etc/nginx/nginx.conf
COPY deploy/nginx/strikefall.conf.template /etc/nginx/templates/strikefall.conf.template
COPY --from=builder --chown=101:101 /workspace/dist/ /usr/share/nginx/html/

# Validate the exact rendered production config while building. Runtime renders
# the same template again so the trusted TLS-proxy CIDR can be deployment-specific.
RUN envsubst '${NGINX_LOCAL_RESOLVERS} ${STRIKEFALL_EDGE_TRUSTED_PROXY_CIDR}' \
      < /etc/nginx/templates/strikefall.conf.template > /tmp/strikefall.conf \
    && nginx -t \
    && rm /tmp/strikefall.conf

USER 101:101
EXPOSE 8080
STOPSIGNAL SIGQUIT
HEALTHCHECK --interval=10s --timeout=3s --start-period=5s --retries=5 \
    CMD ["wget", "--quiet", "--tries=1", "--timeout=2", "--output-document=/dev/null", "http://127.0.0.1:8080/healthz"]

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
